<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE Plugin PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Plugin displayName="Launch QuickLink" minSystemVersion="8.0" name="LaunchQuickLink" rightRequired="" version="1.0">
  <Attributes>
    <Map>
      <entry key="minUpgradableVersion" value="0.1"/>
      <entry key="settingsForm">
        <value>
          <Form name="Launch QuickLink">
            <Attributes>
              <Map>
                <entry key="pageTitle" value="Launch QuickLink"/>
                <entry key="title" value="Launch QuickLink"/>
              </Map>
            </Attributes>
            <Description>Form for Launch QuickLink</Description>
            <Section columns="2" name="Details" type="text">
              <Field displayName="Version" value="1.0" type="string" displayType="textarea" readOnly="true">
                <Attributes>
                  <Map>
                    <entry key="contentIsEscaped" value="true"/>
                  </Map>
                </Attributes>
              </Field>
              <Field displayName="Author" value="Shandeep -  &lt;a href='https://shandeep.dev' target='_blank'> https://shandeep.dev&lt;/a>" type="string" displayType="textarea" readOnly="true">
                <Attributes>
                  <Map>
                    <entry key="contentIsEscaped" value="true"/>
                  </Map>
                </Attributes>
              </Field>

              <Field displayName="How to Use?" value="Below example launches &lt;b>Manage User Access/Request Access &lt;/b> Quicklink directly without navigation &lt;br/>&lt;br/>  &amp;nbsp;&amp;nbsp; &lt;a href='https://iam.acme.com/identityiq/home.jsf?LaunchQL=Manage User Access' target='_blank'> https://iam.acme.com/identityiq/home.jsf?LaunchQL=Manage User Access &lt;/a> &lt;br/>&lt;br/> Similarly any available Quicklink in the navigation panel can be launched by constructing a URL following below pattern, &lt;br/>&lt;br/>  &amp;nbsp;&amp;nbsp; &lt;span>https://iam.acme.com/identityiq/home.jsf?LaunchQL=&lt;b>{QuickLink_Display_Name}&lt;/b>&lt;/span> &lt;br/>&lt;br/> If the Quicklink supports &lt;b>For Me&lt;/b> &amp; &lt;b>For Others&lt;/b> construct a URL following below pattern, &lt;br/>&lt;br/> &lt;b>To Launch For Me:-&lt;/b> &lt;br/> &amp;nbsp;&amp;nbsp; &lt;span>https://iam.acme.com/identityiq/home.jsf?LaunchQL=&lt;b>{QuickLink_Display_Name}&lt;/b>&lt;/span> &lt;br/> &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Or &lt;br/> &amp;nbsp;&amp;nbsp; &lt;span>https://iam.acme.com/identityiq/home.jsf?LaunchQL=&lt;b>{QuickLink_Display_Name}&lt;/b>&amp;LaunchQLFor=Me&lt;/span> &lt;br/>&lt;br/> &lt;b>To Launch For Others:-&lt;/b> &lt;br/> &amp;nbsp;&amp;nbsp; &lt;span>https://iam.acme.com/identityiq/home.jsf?LaunchQL=&lt;b>{QuickLink_Display_Name}&lt;/b>&amp;LaunchQLFor=Others" name="announcement" type="string" displayType="textarea" readOnly="true">
                <Attributes>
                  <Map>
                    <entry key="contentIsEscaped" value="true"/>
                  </Map>
                </Attributes>
              </Field>
            </Section>
          </Form>
        </value>
      </entry>
      <entry key="snippets">
        <value>
          <List>
            <Snippet regexPattern=".*home.jsf" rightRequired="">
              <Scripts>
                <String>ui/js/LaunchQuickLink.js</String>
              </Scripts>
              <StyleSheets/>
            </Snippet>
          </List>
        </value>
      </entry>
    </Map>
  </Attributes>
</Plugin>
